{
  "name": "@context-dot-dev/convex",
  "version": "1.0.0",
  "description": "Convex component for calling the Context.dev API from Convex functions.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/context-dot-dev/convex-component.git"
  },
  "bugs": {
    "url": "https://github.com/context-dot-dev/convex-component/issues"
  },
  "homepage": "https://github.com/context-dot-dev/convex-component#readme",
  "files": [
    "dist",
    "openapispec.json",
    "README.md",
    "PUBLISHING.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    },
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts",
      "import": "./dist/component/_generated/component.js"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.js"
    },
    "./openapispec.json": "./openapispec.json"
  },
  "scripts": {
    "generate:openapi": "openapi-typescript openapispec.json -o src/generated/openapi.ts",
    "codegen": "convex codegen --component-dir src/component",
    "build": "npm run generate:openapi && tsc -p tsconfig.build.json",
    "typecheck": "npm run generate:openapi && tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "convex": ">=1.42.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "convex": "^1.42.0",
    "convex-test": "^0.0.54",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
